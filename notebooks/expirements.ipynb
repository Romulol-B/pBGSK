 "cells": [
  {
   "cell_type": "markdown",
   "id": "intro",
   "metadata": {},
   "source": [
    "# Feature Selection Comparison: pBGSK vs SequentialFeatureSelector\n",
    "\n",
    "This notebook compares the performance and efficiency of the pBGSK algorithm against Scikit-Learn's `SequentialFeatureSelector` (SFS) on two datasets: **Sonar** and **Soybean**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "imports",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import sys\n",
    "import pandas as pd\n",
    "import numpy as np \n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    \"import time\\n\",
    \"from sklearn.model_selection import train_test_split\\n\",
    \"from sklearn.neighbors import KNeighborsClassifier\\n\",
    \"from sklearn.feature_selection import SequentialFeatureSelector, SelectKBest, f_classif, mutual_info_classif, RFE, SelectFromModel\\n\",
    \"from sklearn.ensemble import RandomForestClassifier\\n\",
    \"from sklearn.linear_model import LogisticRegression\\n\",
    \"from sklearn.metrics import accuracy_score\\n\",
    \"from sklearn.preprocessing import LabelEncoder, StandardScaler\\n\",
    "\n",
    "project_root = os.path.abspath(\"..\")\n",
    "if project_root not in sys.path:\n",
    "    sys.path.append(project_root)\n",
    "\n",
    "import src.utils.pBGSK as pBGSK\n",
    "from src.utils.data_importer import data_loader"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "utils",
   "metadata": {},
   "outputs": [],
   "source": [
    "def run_comparison(dataset_name, n_neighbors=5, nfe_total=1000):\n",
    "    print(f\"\\\\n{'='*20} Processing {dataset_name} {'='*20}\")\n",
    "    \n",
    "    # Load data\n",
    "    repo = data_loader(dataset_name)\n",
    "    X = repo.data.features.copy()\n",
    "    y = np.ravel(repo.data.targets)\n",
    "    \n",
    "    # Handle missing values and encoding\n",
    "    X = X.fillna(X.mode().iloc[0])\n",
    "    if X.select_dtypes(include=['object']).shape[1] > 0:\n",
    "        for col in X.select_dtypes(include=['object']).columns:\n",
    "            X[col] = LabelEncoder().fit_transform(X[col].astype(str))\n",
    "    \n",
    "    if isinstance(y[0], (str, np.str_)):\n",
    "        y = LabelEncoder().fit_transform(y)\n",
    "\n",
    "    # Scale data\n",
    "    scaler = StandardScaler()\n",
    "    X_scaled = pd.DataFrame(scaler.fit_transform(X), columns=X.columns)\n",
    "\n",
    "    columns_names = X.columns.tolist()\n",
    "    dim = len(columns_names)\n",
    "    \n",
    "    # Split data\n",
    "    X_train, X_test, y_train, y_test = train_test_split(X_scaled, y, test_size=0.33, random_state=42)\n",
    "    data_tuple = (X_train, X_test, y_train, y_test)\n",
    "    evaluator = pBGSK.FeatureSelectorEvaluator(*data_tuple, knn_val=n_neighbors)\n",
    "    \n",
    "    results = {}\n",
    "\n",
    "    # --- pBGSK ---\n",
    "    print(\"Running pBGSK...\")\n",
    "    pop, best_features_pb, best_score_pb = pBGSK.feature_selection(\n",
    "        data_tuple=data_tuple,\n",
    "        num_population=40,\n",
    "        nfe_total=nfe_total,\n",
    "        lower_k=max(1, int(dim*0.1)),\n",
    "        upper_k=max(2, int(dim*0.8)),\n",
    "        columns_names=columns_names,\n",
    "        knn_val=n_neighbors,\n",
    "        data_set_name=dataset_name\n",
    "    )\n",
    "    score_pb, acc_pb = evaluator.calculate_fitness(best_features_pb)\n",
    "    n_features_pb = np.sum(best_features_pb)\n",
    "    results['pBGSK'] = {'nfe': pop.nfe, 'score': score_pb, 'acc': acc_pb, 'n_features': n_features_pb, 'type': 'metaheuristic'}\n",
    "    \n",
    "    # --- Sequential Feature Selector (Forward) ---\n",
    "    print(\"Running SFS Forward...\")\n",
    "    sfs_nfe_list, sfs_score_list = [], []\n",
    "    current_nfe, best_sfs_score = 0, 2.0\n",
    "    best_sfs_acc, best_sfs_n_features = 0.0, 0\n",
    "    selected_features_idx, remaining_features_idx = [], list(range(dim))\n",
    "    \n",
    "    while current_nfe < nfe_total and len(remaining_features_idx) > 0:\n",
    "        best_new_feature_score, best_new_feature_idx, best_new_feature_acc = 2.0, -1, 0.0\n",
    "        for feat_idx in remaining_features_idx:\n",
    "            current_mask = np.zeros(dim, dtype=bool)\n",
    "            current_mask[selected_features_idx + [feat_idx]] = True\n",
    "            score, acc = evaluator.calculate_fitness(current_mask)\n",
    "            current_nfe += 1\n",
    "            if score < best_new_feature_score:\n",
    "                best_new_feature_score, best_new_feature_idx, best_new_feature_acc = score, feat_idx, acc\n",
    "            if current_nfe >= nfe_total: break\n",
    "        \n",
    "        if best_new_feature_idx != -1:\n",
    "            selected_features_idx.append(best_new_feature_idx)\n",
    "            remaining_features_idx.remove(best_new_feature_idx)\n",
    "            if best_new_feature_score < best_sfs_score:\n",
    "                best_sfs_score = best_new_feature_score\n",
    "                best_sfs_acc = best_new_feature_acc\n",
    "                best_sfs_n_features = len(selected_features_idx)\n",
    "            sfs_nfe_list.append(current_nfe)\n",
    "            sfs_score_list.append(best_new_feature_score)\n",
    "        else: break\n",
    "    results['SFS Forward'] = {'nfe': current_nfe, 'score': best_sfs_score, 'acc': best_sfs_acc, 'n_features': best_sfs_n_features, 'history': (sfs_nfe_list, sfs_score_list), 'type': 'wrapper'}\n",
    "\n",
    "    # --- SelectKBest (Filter) ---\n",
    "    print(\"Running SelectKBest (ANOVA)...\")\n",
    "    skb = SelectKBest(score_func=f_classif, k='all').fit(X_train, y_train)\n",
    "    scores = np.nan_to_num(skb.scores_)\n",
    "    ranked_indices = np.argsort(scores)[::-1]\n",
    "    \n",
    "    best_skb_score, best_skb_acc, best_skb_n_features = 2.0, 0.0, 0\n",
    "    for k in range(1, dim + 1):\n",
    "        mask = np.zeros(dim, dtype=bool)\n",
    "        mask[ranked_indices[:k]] = True\n",
    "        score, acc = evaluator.calculate_fitness(mask)\n",
    "        if score < best_skb_score: \n",
    "            best_skb_score, best_skb_acc, best_skb_n_features = score, acc, k\n",
    "    results['SelectKBest (ANOVA)'] = {'nfe': dim, 'score': best_skb_score, 'acc': best_skb_acc, 'n_features': best_skb_n_features, 'type': 'filter'}\n",
    "\n",
    "    # --- RFE (Recursive Feature Elimination) ---\n",
    "    print(\"Running RFE (RandomForest)...\")\n",
    "    rf = RandomForestClassifier(n_estimators=50, random_state=42)\n",
    "    rfe = RFE(estimator=rf, n_features_to_select=1, step=1)\n",
    "    rfe.fit(X_train, y_train)\n",
    "    ranking = rfe.ranking_\n",
    "    \n",
    "    best_rfe_score, best_rfe_acc, best_rfe_n_features = 2.0, 0.0, 0\n",
    "    for k in range(1, dim + 1):\n",
    "        mask = (ranking <= k)\n",
    "        score, acc = evaluator.calculate_fitness(mask)\n",
    "        if score < best_rfe_score: \n",
    "            best_rfe_score, best_rfe_acc, best_rfe_n_features = score, acc, k\n",
    "    results['RFE (RF)'] = {'nfe': dim, 'score': best_rfe_score, 'acc': best_rfe_acc, 'n_features': best_rfe_n_features, 'type': 'wrapper'}\n",
    "\n",
    "    # --- SelectFromModel (Embedded) ---\n",
    "    print(\"Running SelectFromModel (L1)...\")\n",
    "    l1_model = LogisticRegression(penalty='l1', solver='liblinear', random_state=42)\n",
    "    sfm = SelectFromModel(l1_model, threshold='mean').fit(X_train, y_train)\n",
    "    mask = sfm.get_support()\n",
    "    score, acc = evaluator.calculate_fitness(mask)\n",
    "    n_features = np.sum(mask)\n",
    "    results['SelectFromModel (L1)'] = {'nfe': 1, 'score': score, 'acc': acc, 'n_features': n_features, 'type': 'embedded'}\n",
    "\n",
    "    return results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "run_sonar",
   "metadata": {},
   "outputs": [],
   "source": [
    "sonar_res = run_comparison(\"sonar\", n_neighbors=3, nfe_total=1000)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "run_soybean",
   "metadata": {},
   "outputs": [],
   "source": [
    "soybean_res = run_comparison(\"soybean\", n_neighbors=3, nfe_total=1000)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "plotting",
   "metadata": {},
   "outputs": [],
   "source": [
    "def plot_results(results, title):\n",
    "    # 1. NFE vs Score Plot (for SFS and pBGSK)\n",
    "    plt.figure(figsize=(12, 6))\n",
    "    \n",
    "    # Plot SFS history\n",
    "    nfe_sfs, score_sfs = results['SFS Forward']['history']\n",
    "    plt.plot(nfe_sfs, score_sfs, 'o-', alpha=0.5, label='SFS Forward (Path)')\n",
    "    \n",
    "    # Plot final points for all\n",
    "    markers = {'metaheuristic': '*', 'wrapper': 'o', 'filter': 's', 'embedded': 'D'}\n",
    "    colors = sns.color_palette(\"husl\", len(results))\n",
    "    \n",
    "    for i, (name, res) in enumerate(results.items()):\n",
    "        plt.scatter(res['nfe'], res['score'], \n",
    "                    marker=markers.get(res['type'], 'o'), \n",
    "                    s=200 if name == 'pBGSK' else 100, \n",
    "                    label=f\"{name} (Final: {res['score']:.4f})\",\n",
    "                    color=colors[i], zorder=5)\n",
    "    \n",
    "    plt.xlabel('Number of Function Evaluations (NFE)')\n",
    "    plt.ylabel('Fitness Score (Lower is better)')\n",
    "    plt.title(f'NFE vs Score: {title}')\n",
    "    plt.legend(bbox_to_anchor=(1.05, 1), loc='upper left')\n",
    "    plt.grid(True, linestyle='--', alpha=0.7)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    # 2. Bar Charts for Score, Accuracy, and Number of Features Comparison\n",
    "    fig, axes = plt.subplots(1, 3, figsize=(18, 6))\n",
    "    names = list(results.keys())\n",
    "    scores = [r['score'] for r in results.values()]\n",
    "    accs = [r['acc'] for r in results.values()]\n",
    "    n_feats = [r['n_features'] for r in results.values()]\n",
    "    \n",
    "    sns.barplot(x=names, y=scores, palette=\"viridis\", ax=axes[0], hue=names, legend=False)\n",
    "    axes[0].tick_params(axis='x', rotation=45)\n",
    "    axes[0].set_ylabel('Fitness Score (Lower is Better)')\n",
    "    axes[0].set_title('Score Comparison')\n",
    "    axes[0].set_ylim(min(scores)*0.9, max(scores)*1.1)\n",
    "    \n",
    "    sns.barplot(x=names, y=accs, palette=\"magma\", ax=axes[1], hue=names, legend=False)\n",
    "    axes[1].tick_params(axis='x', rotation=45)\n",
    "    axes[1].set_ylabel('Accuracy (Higher is Better)')\n",
    "    axes[1].set_title('Accuracy Comparison')\n",
    "    axes[1].set_ylim(max(0, min(accs)*0.9), min(1.0, max(accs)*1.1))\n",
    "    \n",
    "    sns.barplot(x=names, y=n_feats, palette=\"cubehelix\", ax=axes[2], hue=names, legend=False)\n",
    "    axes[2].tick_params(axis='x', rotation=45)\n",
    "    axes[2].set_ylabel('Number of Selected Features')\n",
    "    axes[2].set_title('Feature Count Comparison')\n",
    "    \n",
    "    plt.suptitle(f'Metrics Comparison: {title}', fontsize=16)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "plot_results(sonar_res, \"Sonar Dataset\")\n",
    "plot_results(soybean_res, \"Soybean Dataset\")"
   ]
  }
 ],
